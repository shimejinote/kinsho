{
  "platform": {
    "apiRuntime": "node:20"
  },
  "trailingSlash": "auto",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/_next/static/*",
      "*.{css,js,jpg,jpeg,png,gif,svg,ico,webp,woff,woff2,ttf}"
    ]
  },
  "routes": [
    {
      "route": "/.env",
      "statusCode": 404
    },
    {
      "route": "/.env.*",
      "statusCode": 404
    },
    {
      "route": "/.git/*",
      "statusCode": 404
    },
    {
      "route": "/.aws/*",
      "statusCode": 404
    },
    {
      "route": "/wp-admin*",
      "statusCode": 404
    },
    {
      "route": "/wp-login.php",
      "statusCode": 404
    },
    {
      "route": "/xmlrpc.php",
      "statusCode": 404
    },
    {
      "route": "/phpmyadmin*",
      "statusCode": 404
    },
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"],
      "headers": {
        "Cache-Control": "no-store",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "route": "/_next/static/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/*.{css,js,jpg,jpeg,png,gif,svg,ico,webp,woff,woff2,ttf}",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/apps/*",
      "rewrite": "/apps/index.html"
    },
    {
      "route": "/archive/void/*",
      "rewrite": "/archive/void/index.html"
    },
    {
      "route": "/archive/journey/*",
      "rewrite": "/archive/journey/index.html"
    },
    {
      "route": "/sample-app/*",
      "rewrite": "/sample-app/index.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "redirect": "/",
      "statusCode": 302
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "X-Frame-Options": "DENY",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=(), payment=()",
    "Cross-Origin-Opener-Policy": "same-origin",
    "Cross-Origin-Resource-Policy": "same-site",
    "Content-Security-Policy": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; worker-src 'self'"
  }
}
