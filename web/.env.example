# Canonical public site URL (no trailing slash). Used for OG / robots / sitemap.
NEXT_PUBLIC_SITE_URL=https://shimeji.blog

# Leave empty to use SWA managed API via relative /api/*
# For BYO Consumption Function App, set e.g.:
# NEXT_PUBLIC_API_BASE_URL=https://func-kinsho-xxxx.azurewebsites.net
NEXT_PUBLIC_API_BASE_URL=
